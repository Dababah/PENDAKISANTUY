# ============================================================
# PENDAKISANTUY - Environment Variables
# Salin file ini menjadi .env.local dan isi nilainya
# ============================================================

# Database (Neon PostgreSQL)
# Dapatkan dari: https://console.neon.tech
DATABASE_URL="postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/pendakisantuy?sslmode=require"

# Admin Password (ganti dengan password yang kuat!)
ADMIN_PASSWORD="admin123"

# WhatsApp Number (format internasional tanpa + dan spasi)
NEXT_PUBLIC_WHATSAPP_NUMBER="6281234567890"

# App URL (ubah setelah deploy ke Vercel)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
